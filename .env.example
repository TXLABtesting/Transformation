# ============================================================================
# AI Transformation Portal — environment configuration (production handover)
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in every value marked (REQUIRED).
# Values marked (build-time) must be set BEFORE `npm run build` / docker build,
# because Next.js inlines NEXT_PUBLIC_* variables into the client bundle.
# Nothing else in the code needs to change — only the values below.
# ============================================================================

# ---- Data layer ------------------------------------------------------------
# "local" = browser localStorage (static demo). "api" = Postgres via the API
# routes. Production MUST be "api".  (build-time)
NEXT_PUBLIC_DATA_MODE=api

# Postgres connection string.  (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL=postgresql://portal:portal@localhost:5432/transformation?schema=public

# ---- Sessions / security ---------------------------------------------------
# Secret used to sign session tokens/cookies. Generate with:
#   openssl rand -hex 32
# (REQUIRED)
SESSION_SECRET=
# Session lifetime in hours (default 12).
SESSION_TTL_HOURS=12
# Shared secret guarding writes to /api/state. Set for any shared deployment.
STATE_API_TOKEN=

# ---- UAE PASS SSO (OpenID Connect) -----------------------------------------
# "mock" jumps straight into the app (demo). "live" uses the real IdP and
# requires the credentials below.  (build-time)
NEXT_PUBLIC_UAEPASS_MODE=live
UAEPASS_ENV=production                 # staging | production
UAEPASS_CLIENT_ID=                     # (REQUIRED for live)
UAEPASS_CLIENT_SECRET=                 # (REQUIRED for live)
UAEPASS_REDIRECT_URI=https://YOUR_HOST/api/auth/uaepass/callback   # (REQUIRED for live)
# Optional overrides (sensible defaults are applied per UAEPASS_ENV):
# UAEPASS_BASE_URL=https://id.uaepass.ae/idshub
# UAEPASS_SCOPE=urn:uae:digitalid:profile:general
# UAEPASS_ACR=urn:safelayer:tws:policies:authentication:level:low

# ---- Default role (fallback only; real role comes from the users table) ----
NEXT_PUBLIC_DEFAULT_ROLE=entity        # (build-time)

# ---- Internal AI reviewer (مراجعة ذكية) ------------------------------------
# Any OpenAI-compatible chat-completions endpoint. If unset/unreachable the
# app falls back to the built-in heuristic reviewer.
AI_API_BASE_URL=http://localhost:8000/v1
AI_API_KEY=
AI_MODEL=default

# ---- Sub-path hosting (only if served from /<path>, e.g. GitHub Pages) -----
# Leave unset when hosting at a domain root.  (build-time)
# NEXT_PUBLIC_BASE_PATH=/Transformation

# ---- Demo switches — MUST stay 0 in production -----------------------------
NEXT_PUBLIC_DEMO_MODE=0    # 1 = show the role-switcher tabs (demo/testing only)
NEXT_PUBLIC_DEMO_DATA=0    # 1 = seed the mock portfolio (presentation only)
