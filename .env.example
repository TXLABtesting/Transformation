# ------------------------------------------------------------------
# AI Transformation Portal — environment configuration
# ------------------------------------------------------------------

# Data layer: "local" = browser localStorage (default, static-export friendly),
# "api" = talk to the Next.js API routes backed by Postgres (Docker deployment).
NEXT_PUBLIC_DATA_MODE=local

# Postgres connection (only needed when NEXT_PUBLIC_DATA_MODE=api)
DATABASE_URL=postgresql://portal:portal@localhost:5432/transformation?schema=public

# Optional shared secret guarding writes to /api/state (Bearer token). Leave
# empty for the single-tenant demo; set it for any shared deployment.
STATE_API_TOKEN=

# Internal, self-hosted AI model used by the "مراجعة ذكية" (AI review) step.
# Any OpenAI-compatible chat-completions endpoint. If unset/unreachable the
# app falls back to the built-in heuristic reviewer.
AI_API_BASE_URL=http://localhost:8000/v1
AI_API_KEY=
AI_MODEL=default

# For GitHub Pages project sites served from /<repo> (e.g. /Transformation)
# NEXT_PUBLIC_BASE_PATH=/Transformation

# ---- UAE PASS SSO (OpenID Connect) ----
# Presentation default is a mock login (button jumps straight into the app).
# Set to "live" to use the real UAE PASS IdP (requires the credentials below).
NEXT_PUBLIC_UAEPASS_MODE=mock
UAEPASS_ENV=staging            # staging | production
UAEPASS_CLIENT_ID=
UAEPASS_CLIENT_SECRET=
UAEPASS_REDIRECT_URI=http://localhost:3000/api/auth/uaepass/callback
# Optional overrides:
# UAEPASS_BASE_URL=https://stg-id.uaepass.ae/idshub
# UAEPASS_SCOPE=urn:uae:digitalid:profile:general
# UAEPASS_ACR=urn:safelayer:tws:policies:authentication:level:low
