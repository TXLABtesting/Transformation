# ------------------------------------------------------------------
# AI Transformation Portal — environment configuration
# ------------------------------------------------------------------

# Data layer: "local" = browser localStorage (default, static-export friendly),
# "api" = talk to the Next.js API routes backed by Postgres (Docker deployment).
NEXT_PUBLIC_DATA_MODE=local

# Postgres connection (only needed when NEXT_PUBLIC_DATA_MODE=api)
DATABASE_URL=postgresql://portal:portal@localhost:5432/transformation?schema=public

# Internal, self-hosted AI model used by the "مراجعة ذكية" (AI review) step.
# Any OpenAI-compatible chat-completions endpoint. If unset/unreachable the
# app falls back to the built-in heuristic reviewer.
AI_API_BASE_URL=http://localhost:8000/v1
AI_API_KEY=
AI_MODEL=default

# For GitHub Pages project sites served from /<repo> (e.g. /Transformation)
# NEXT_PUBLIC_BASE_PATH=/Transformation
