// ============================================================================
// AI Transformation Portal — relational schema (Postgres)
// Properly normalized tables for the production deployment. The static demo
// runs on localStorage; the Docker/server deployment uses these tables.
// Naming: camelCase in the client, snake_case tables/columns via @map.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Reference data
// ---------------------------------------------------------------------------

/// Government entity (الجهة) — the 34 federal entities + the session entity.
model Entity {
  id        String   @id @default(cuid())
  nameAr    String   @unique @map("name_ar")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  items        Item[]
  reps         EntityRep[]
  streamOwners StreamOwner[]

  @@map("entities")
}

/// Transformation stream (المسار) — 5 predefined; head = رئيس المسار.
model Stream {
  id        String  @id // capacity | tech | ops | strategy | services
  nameAr    String  @unique @map("name_ar")
  descAr    String  @map("desc_ar")
  headName  String? @map("head_name")
  sortOrder Int     @default(0) @map("sort_order")

  items        Item[]
  streamOwners StreamOwner[]

  @@map("streams")
}

/// Program phase (مراحل البرنامج) with its deadline — editable by the committee.
model ProgramPhase {
  idx      Int    @id
  nameAr   String @map("name_ar")
  descAr   String @map("desc_ar")
  deadline String // ISO date

  @@map("program_phases")
}

/// Execution batch (الدفعات الربعية) — the 5 fixed quarterly milestones.
model ExecBatch {
  id       Int    @id
  nameAr   String @unique @map("name_ar")
  periodAr String @map("period_ar")
  descAr   String @map("desc_ar")
  startsOn String @map("starts_on") // ISO date
  endsOn   String @map("ends_on") // ISO date

  @@map("exec_batches")
}

/// Key-value app settings (e.g. approved committee budget).
model Setting {
  key   String @id
  value String

  @@map("settings")
}

// ---------------------------------------------------------------------------
// Team setup (تسجيل فريق العمل) — per entity
// ---------------------------------------------------------------------------

/// Official entity representative (ممثل الجهة).
model EntityRep {
  id       String @id @default(cuid())
  entityId String @map("entity_id")
  name     String
  position String @default("")
  email    String @default("")
  phone    String @default("")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId])
  @@map("entity_reps")
}

/// Per-stream owner inside an entity (مسؤول المسار في الجهة).
model StreamOwner {
  id       String  @id @default(cuid())
  entityId String  @map("entity_id")
  streamId String  @map("stream_id")
  name     String  @default("")
  position String  @default("")
  email    String  @default("")
  phone    String  @default("")
  isSelf   Boolean @default(false) @map("is_self")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@unique([entityId, streamId])
  @@map("stream_owners")
}

// ---------------------------------------------------------------------------
// Items (العناصر) + child tables
// ---------------------------------------------------------------------------

enum WfState {
  draft
  ent1
  exec
  launch
  done

  @@map("wf_state")
}

enum ItemType {
  project
  initiative
  operation
  service

  @@map("item_type")
}

model Item {
  id       String   @id
  type     ItemType
  streamId String   @map("stream_id")
  entityId String   @map("entity_id")
  title    String
  desc     String   @default("")
  wf       WfState  @default(draft)
  approval String   @default("مسودة")

  // assessment
  priority          String?
  rank              Int?
  complexity        String?
  impact            String?
  status            String?
  transformability  String?
  readiness         String?
  usageIntensity    String? @map("usage_intensity")
  transformPriority String? @map("transform_priority")
  automationPct     Int?    @map("automation_pct")
  automationLevel   String? @map("automation_level")
  automationSystem  String? @map("automation_system")
  complexityLevel   String? @map("complexity_level")
  progress          Int     @default(0)

  // outcomes / scope
  scopeOfWork         String? @map("scope_of_work")
  budget              String?
  budgetAmount        BigInt? @map("budget_amount") // parsed درهم amount
  scopeApproval       String? @map("scope_approval")
  scopeFile           String? @map("scope_file")
  expectedOutputs     String? @map("expected_outputs")
  expectedOutcomes    String? @map("expected_outcomes")
  expectedImpact      String? @map("expected_impact")
  aiModels            Int?    @map("ai_models")
  targetPct           Int?    @map("target_pct")
  endDate             String? @map("end_date")

  // operation-specific
  opType        String? @map("op_type")
  subActivities String? @map("sub_activities")
  sector        String?
  dept          String?
  section       String?

  // service-specific
  serviceOwner        String? @map("service_owner")
  targetUsers         String? @map("target_users")
  currentJourney      String? @map("current_journey")
  painPoints          String? @map("pain_points")
  expectedImprovement String? @map("expected_improvement")

  // execution planning
  execBatch String? @map("exec_batch") // FK by name into exec_batches.name_ar (kept loose for flexibility)
  // centrally-managed launch plans the item is attached to (إدارة خطط الإطلاق)
  // — one batch per item, but potentially several launches within that batch
  launchPlanLinks ItemLaunchPlan[]

  // returned-with-notes state (ملاحظات ممثل الجهة)
  retType String? @map("ret_type") // info | reject
  retFrom String? @map("ret_from")
  retNote String? @map("ret_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  entity Entity @relation(fields: [entityId], references: [id])
  stream Stream @relation(fields: [streamId], references: [id])

  checklist     ExecChecklistItem[]
  subMilestones SubMilestone[]
  launches      ItemLaunch[]
  logs          LogEntry[]
  nomination    Nomination?
  funding       Funding?
  fundingCancel FundingCancellation?

  @@index([entityId])
  @@index([streamId])
  @@index([wf])
  @@map("items")
}

/// Centrally managed launch plans (إدارة خطط الإطلاق) — one per launch event,
/// defined per execution batch; may carry the group-level scope and budget
/// for the set of operations / services / projects launched together.
model LaunchPlan {
  id           String  @id
  batch        String // batch name (loose FK into exec_batches.name_ar)
  title        String
  ltype        String  @default("")
  date         String  @default("")
  desc         String  @default("")
  scope        String  @default("")
  budget       String  @default("")
  budgetAmount BigInt? @map("budget_amount") // parsed درهم amount (execution — funding totals)
  launchBudget String  @default("") @map("launch_budget") // launch/event cost, informational

  itemLinks ItemLaunchPlan[]

  @@index([batch])
  @@map("launch_plans")
}

/// Join: which items participate in which managed launch plan.
model ItemLaunchPlan {
  itemId       String @map("item_id")
  launchPlanId String @map("launch_plan_id")

  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  launchPlan LaunchPlan @relation(fields: [launchPlanId], references: [id], onDelete: Cascade)

  @@id([itemId, launchPlanId])
  @@map("item_launch_plans")
}

/// Execution checklist rows (بنود التنفيذ) — agents/testing/pilot per item.
model ExecChecklistItem {
  id      String  @id @default(cuid())
  itemId  String  @map("item_id")
  key     String // agents | testing | pilot
  label   String
  status  String  @default("لم تبدأ") // لم تبدأ | مكتمل | متأخر
  newDate String? @map("new_date")
  reason  String?
  sortOrder Int   @default(0) @map("sort_order")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, key])
  @@map("exec_checklist_items")
}

/// Per-item sub-milestones inside the selected execution batch.
model SubMilestone {
  id        String  @id @default(cuid())
  itemId    String  @map("item_id")
  batchName String  @map("batch_name")
  name      String
  startsOn  String? @map("starts_on")
  endsOn    String? @map("ends_on")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("sub_milestones")
}

/// Launch plans (خطط الإطلاق) — shared across items via item_launches.
/// Completion is synchronized: `done` lives here, once for all sharers.
model Launch {
  id     String  @id @default(cuid())
  title  String
  ltype  String
  date   String
  desc   String  @default("")
  status String  @default("مخطط")
  done   Boolean @default(false)
  doneAt DateTime? @map("done_at")

  items ItemLaunch[]

  @@unique([title, date])
  @@map("launches")
}

/// Join: which items participate in which launch (التي تُطلق معاً).
model ItemLaunch {
  itemId   String  @map("item_id")
  launchId String  @map("launch_id")
  shared   Boolean @default(false)

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  launch Launch @relation(fields: [launchId], references: [id], onDelete: Cascade)

  @@id([itemId, launchId])
  @@map("item_launches")
}

/// Approval / action log (سجل الاعتمادات والإجراءات).
model LogEntry {
  id       String   @id @default(cuid())
  itemId   String   @map("item_id")
  action   String // submit | approve | reject | info | nominate | fund | unfund | cancelFund | budget
  byName   String   @map("by_name")
  roleName String   @map("role_name")
  at       DateTime @default(now())
  note     String   @default("")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, at])
  @@map("log_entries")
}

/// Nomination by رئيس المسار (or synthesized on direct committee funding).
model Nomination {
  itemId   String   @id @map("item_id")
  byName   String   @map("by_name")
  roleName String   @map("role_name")
  streamId String   @map("stream_id")
  at       DateTime
  direct   Boolean  @default(false)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("nominations")
}

/// Committee funding decision (معتمد للتمويل).
model Funding {
  itemId String   @id @map("item_id")
  byName String   @default("اللجنة الوطنية") @map("by_name")
  at     DateTime
  direct Boolean  @default(false)

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("fundings")
}

/// Funding cancellation with its required reason (يُبلَّغ به صاحب العنصر).
model FundingCancellation {
  itemId String   @id @map("item_id")
  byName String   @map("by_name")
  at     DateTime
  reason String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("funding_cancellations")
}

// ---------------------------------------------------------------------------
// Demo sync blob (used by /api/state for the client-side demo persistence)
// ---------------------------------------------------------------------------
model AppState {
  id        String   @id @default("singleton")
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_state")
}
